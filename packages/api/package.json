    "express": "^4.18",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jose": "^5.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2",
    "@types/express": "^4",
    "@types/node": "^20",
    "tsx": "^4.7",
    "typescript": "^5.4"
  }
}
