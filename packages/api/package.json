{
  "name": "@saaafe/api",
  "version": "0.1.0",
  "description": "AI analysis API server for saaafe — multi-level risk assessment",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shipooor/saaafe.git",
    "directory": "packages/api"
  },
  "keywords": ["saaafe", "ai", "risk-analysis", "claude", "wdk", "tether"],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
