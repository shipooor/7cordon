# 7cordon — Environment Variables
# Copy this file: cp .env.example .env

# ─── Required ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...              # Claude API key (https://console.anthropic.com)
CORDON7_API_KEY=your-shared-secret         # API key for SDK <-> API authentication

# ─── Optional: Server ───────────────────────────────────────────
PORT=3000                                  # API server port (default: 3000)
NODE_ENV=development                       # development | production
CORS_ORIGIN=http://localhost:4000          # CORS allowed origins (comma-separated)

# ─── Optional: Auth ─────────────────────────────────────────────
CORDON7_JWT_SECRET=                         # JWT secret for wallet auth (auto-generated if not set)
                                           # Must be >= 32 chars in production

# ─── Optional: Data Sources ─────────────────────────────────────
ARBISCAN_API_KEY=                          # Arbiscan API key (contract source for L2 analysis)
ANTHROPIC_BASE_URL=                        # Custom Anthropic endpoint (e.g., OpenRouter)

# ─── Optional: AI Models ────────────────────────────────────────
CORDON7_L1_MODEL=                           # L1 model override (default: claude-haiku-4-5-20251001)
CORDON7_L2_MODEL=                           # L2 model override (default: claude-opus-4-6)

# ─── Optional: Wallet / SDK ─────────────────────────────────────
EVM_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/demo   # EVM RPC endpoint
WDK_SEED_PHRASE=                           # BIP-39 mnemonic for WDK wallet (demo/MCP)

# ─── Optional: Spark Payments ───────────────────────────────────
ENABLE_SPARK_PAYMENTS=false                # Enable streaming USDT micropayments
CORDON7_SPARK_ADDRESS=                      # Operator's Spark address for fee collection

# ─── Optional: ERC-4337 (Account Abstraction) ───────────────────
ERC4337_BUNDLER_URL=                       # Bundler RPC endpoint
ERC4337_PAYMASTER_URL=                     # Paymaster RPC endpoint

# ─── Optional: Dashboard ────────────────────────────────────────
VITE_API_URL=http://localhost:3000         # API URL for dashboard (VITE_ prefix required)
